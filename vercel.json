{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/turtletalk",
      "permanent": false,
      "has": [{ "type": "host", "value": "www.turtletalk.io" }]
    }
  ],
  "headers": [
    {
      "source": "/resume.tex",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
