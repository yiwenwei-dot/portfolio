{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/turtletalk.html",
      "has": [{ "type": "host", "value": "www\\.turtletalk\\.io" }]
    },
    {
      "source": "/index.html",
      "destination": "/turtletalk.html",
      "has": [{ "type": "host", "value": "www\\.turtletalk\\.io" }]
    }
  ],
  "headers": [
    {
      "source": "/resume.tex",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
